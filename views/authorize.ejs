<%- include('header') %>

<div class="card" style="max-width: 600px; margin: 40px auto;">
    <h2>授权确认</h2>

    <div class="alert alert-info" style="margin-bottom: 24px;">
        <div style="display: flex; align-items: center; gap: 12px;">
            <div style="width: 48px; height: 48px; background: #667eea; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 20px; font-weight: bold;">
                <%= client.name.charAt(0).toUpperCase() %>
            </div>
            <div>
                <div style="font-weight: 600; font-size: 16px;">
                    <strong><%= client.name %></strong>
                </div>
                <div style="color: #888; font-size: 13px;">
                    <%= client.description || 'OAuth2 客户端应用' %>
                </div>
                <% if (pkceEnabled) { %>
                    <span class="badge" style="margin-top: 4px;">🔐 PKCE 安全保护</span>
                <% } %>
            </div>
        </div>
    </div>

    <div class="section">
        <h3>正在登录的账号</h3>
        <div class="user-info" style="margin-bottom: 0;">
            <div class="avatar">
                <% if (user && user.avatar) { %>
                    <img src="<%= user.avatar %>" alt="avatar">
                <% } else if (user) { %>
                    <%= (user.nickname || user.email || 'U').charAt(0).toUpperCase() %>
                <% } %>
            </div>
            <div>
                <p style="font-weight: 500;"><%= user && user.nickname ? user.nickname : '用户' %></p>
                <p style="color: #888; font-size: 13px; margin: 0;">
                    <%= user && user.email ? user.email : (user && user.phone ? user.phone : '') %>
                </p>
            </div>
        </div>
    </div>

    <div class="section">
        <h3>请求的权限</h3>
        <ul style="list-style: none; padding: 0;">
            <% scopeDescriptions.forEach(function(s) { %>
                <li style="display: flex; align-items: flex-start; gap: 10px; padding: 12px 0; border-bottom: 1px solid #f0f0f0;">
                    <span style="color: #667eea; font-size: 18px;">✅</span>
                    <div>
                        <div style="font-weight: 500;"><%= s.label %></div>
                        <div style="color: #888; font-size: 13px; margin-top: 2px;"><%= s.description %></div>
                    </div>
                </li>
            <% }); %>
        </ul>
    </div>

    <div style="background: #fff3cd; padding: 12px 16px; border-radius: 8px; font-size: 13px; color: #856404; margin-bottom: 20px;">
        ⚠️ 请确认您信任 <strong><%= client.name %></strong>，授权后该应用将可以访问您的上述信息。
    </div>

    <form method="POST" action="/oauth2/authorize">
        <input type="hidden" name="client_id" value="<%= client.clientId %>">
        <input type="hidden" name="redirect_uri" value="<%= redirectUri %>">
        <input type="hidden" name="scope" value="<%= scope.join(' ') %>">
        <input type="hidden" name="code_challenge" value="<%= codeChallenge %>">
        <input type="hidden" name="code_challenge_method" value="<%= codeChallengeMethod %>">
        <input type="hidden" name="state" value="<%= state %>">

        <div class="actions" style="justify-content: flex-end;">
            <button type="submit" name="action" value="deny" class="btn btn-secondary">拒绝</button>
            <button type="submit" name="action" value="allow" class="btn btn-primary">授权</button>
        </div>
    </form>
</div>

<%- include('footer') %>
