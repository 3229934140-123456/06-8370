<%- include('header') %>

<div class="login-wrapper">
    <div class="card">
        <h2 style="text-align: center;">账号登录</h2>

        <% if (error) { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>
        <% if (success) { %>
            <div class="alert alert-success"><%= success %></div>
        <% } %>

        <form method="POST" action="/login/password">
            <div class="form-group">
                <label>邮箱或手机号</label>
                <input type="text" name="identifier" placeholder="请输入邮箱或手机号" required>
            </div>
            <div class="form-group">
                <label>密码</label>
                <input type="password" name="password" placeholder="请输入密码" required>
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%;">登录</button>
        </form>

        <div class="divider"><span>或使用第三方账号登录</span></div>

        <div class="oauth-buttons">
            <a href="/auth/github" class="btn btn-github">
                <span class="provider-icon">🐙</span> 使用 GitHub 登录
            </a>
            <a href="/auth/google" class="btn btn-google">
                <span class="provider-icon">🔍</span> 使用 Google 登录
            </a>
            <a href="/auth/wechat" class="btn btn-wechat">
                <span class="provider-icon">💬</span> 使用 微信 登录
            </a>
        </div>

        <div style="text-align: center; margin-top: 24px; font-size: 13px; color: #888;">
            还没有账号？<a href="/register" style="color: #667eea;">立即注册</a>
        </div>
    </div>
</div>

<%- include('footer') %>
