<%- include('header') %>

<% if (success) { %>
    <div class="alert alert-success"><%= success %></div>
<% } %>
<% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
<% } %>

<div class="card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h2 style="margin: 0;">OAuth2 客户端管理</h2>
        <a href="/admin/clients/new" class="btn btn-primary">+ 新建客户端</a>
    </div>

    <% if (clients && clients.length > 0) { %>
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="border-bottom: 2px solid #eee;">
                    <th style="text-align: left; padding: 12px 8px;">名称</th>
                    <th style="text-align: left; padding: 12px 8px;">Client ID</th>
                    <th style="text-align: left; padding: 12px 8px;">回调地址</th>
                    <th style="text-align: left; padding: 12px 8px;">授权范围</th>
                    <th style="text-align: left; padding: 12px 8px;">状态</th>
                    <th style="text-align: left; padding: 12px 8px;">操作</th>
                </tr>
            </thead>
            <tbody>
                <% clients.forEach(function(client) { %>
                    <tr style="border-bottom: 1px solid #f0f0f0;">
                        <td style="padding: 12px 8px;">
                            <div style="font-weight: 500;"><%= client.name %></div>
                            <div style="font-size: 12px; color: #888;"><%= client.description || '' %></div>
                        </td>
                        <td style="padding: 12px 8px; font-family: monospace; font-size: 12px;">
                            <%= client.clientId %>
                        </td>
                        <td style="padding: 12px 8px; font-size: 12px; max-width: 200px;">
                            <%= client.redirectUris.slice(0, 2).join('<br>') %>
                            <% if (client.redirectUris.length > 2) { %>
                                <div style="color: #888;">+ <%= client.redirectUris.length - 2 %> 更多</div>
                            <% } %>
                        </td>
                        <td style="padding: 12px 8px; font-size: 12px;">
                            <%= client.allowedScopes.slice(0, 3).join(', ') %>
                            <% if (client.allowedScopes.length > 3) { %>
                                <div style="color: #888;">+ <%= client.allowedScopes.length - 3 %> 更多</div>
                            <% } %>
                        </td>
                        <td style="padding: 12px 8px;">
                            <% if (client.isActive) { %>
                                <span class="status-bound account-status">启用</span>
                            <% } else { %>
                                <span class="status-unbound account-status">禁用</span>
                            <% } %>
                            <% if (client.requireConsent) { %>
                                <div style="font-size: 11px; color: #888; margin-top: 2px;">需用户确认</div>
                            <% } %>
                        </td>
                        <td style="padding: 12px 8px;">
                            <div style="display: flex; gap: 4px; flex-wrap: wrap;">
                                <a href="/admin/clients/<%= client.id %>" class="btn btn-secondary" style="padding: 4px 10px; font-size: 12px;">编辑</a>
                                <form method="POST" action="/admin/clients/<%= client.id %>/rotate-secret" style="display: inline;">
                                    <button type="submit" class="btn btn-secondary" style="padding: 4px 10px; font-size: 12px;" onclick="return confirm('确定要重置密钥吗？')">重置密钥</button>
                                </form>
                                <form method="POST" action="/admin/clients/<%= client.id %>/delete" style="display: inline;" onsubmit="return confirm('确定要删除该客户端吗？');">
                                    <button type="submit" class="btn btn-danger" style="padding: 4px 10px; font-size: 12px;">删除</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } else { %>
        <div style="text-align: center; padding: 48px 0; color: #888;">
            暂无客户端，点击上方"新建客户端"按钮创建
        </div>
    <% } %>
</div>

<%- include('footer') %>
