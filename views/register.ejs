<%- include('header') %>

<div class="login-wrapper">
    <div class="card">
        <h2 style="text-align: center;">
            <% if (typeof provider !== 'undefined' && provider) { %>
                完善 <%= provider === 'github' ? 'GitHub' : provider === 'google' ? 'Google' : '微信' %> 账号信息
            <% } else { %>
                注册新账号
            <% } %>
        </h2>

        <% if (typeof userInfo !== 'undefined' && userInfo) { %>
            <div class="alert alert-info">
                <% if (userInfo.nickname) { %>欢迎，<strong><%= userInfo.nickname %></strong>！<% } %>
                请补充以下信息以完成注册。
            </div>
        <% } %>

        <% if (error) { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>

        <form method="POST" action="/register">
            <div class="form-group">
                <label>邮箱 <span style="color: #ff4757;">*</span></label>
                <input type="email" name="email" placeholder="请输入邮箱地址"
                    value="<%= typeof userInfo !== 'undefined' && userInfo && userInfo.email ? userInfo.email : '' %>">
                <p class="hint">邮箱或手机号至少填写一项</p>
            </div>
            <div class="form-group">
                <label>手机号</label>
                <input type="tel" name="phone" placeholder="请输入手机号"
                    value="<%= typeof userInfo !== 'undefined' && userInfo && userInfo.phone ? userInfo.phone : '' %>">
            </div>
            <div class="form-group">
                <label>昵称</label>
                <input type="text" name="nickname" placeholder="请输入昵称"
                    value="<%= typeof userInfo !== 'undefined' && userInfo && userInfo.nickname ? userInfo.nickname : '' %>">
            </div>
            <div class="form-group">
                <label>登录密码</label>
                <input type="password" name="password" placeholder="至少6位，用于账号密码登录">
                <p class="hint">设置密码后可使用邮箱/手机号+密码登录</p>
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%;">
                <% if (typeof provider !== 'undefined' && provider) { %>完成绑定并创建账号<% } else { %>注册账号<% } %>
            </button>
        </form>

        <div style="text-align: center; margin-top: 24px; font-size: 13px; color: #888;">
            已有账号？<a href="/login" style="color: #667eea;">直接登录</a>
        </div>
    </div>
</div>

<%- include('footer') %>
